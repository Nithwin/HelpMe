{
  "manifest_version": 3,
  "name": "ExamPilot Assistant",
  "version": "2.1.0",
  "description": "Smart, undetectable AI-powered Autopilot exam assistant.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content-loader.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.js",
        "assets/*.css",
        "assets/*.svg",
        "assets/*.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "ask-selection": {
      "suggested_key": { "default": "Alt+A", "mac": "Alt+A" },
      "description": "Ask AI about the selected text"
    },
    "ask-mcq-auto": {
      "suggested_key": { "default": "Alt+Q", "mac": "Alt+Q" },
      "description": "Autonomous MCQ solver (selection fallback to auto-scan)"
    },
    "toggle-and-focus": {
      "suggested_key": { "default": "Ctrl+Space", "mac": "Command+Space" },
      "description": "Toggle Assistant Panel"
    },
    "ask-coding-auto": {
      "suggested_key": { "default": "Alt+C", "mac": "Alt+C" },
      "description": "Autonomous code solver (extracts problem automatically)"
    }
  },

  "action": {
    "default_icon": { "16": "icon.png", "48": "icon.png", "128": "icon.png" },
    "default_popup": "index.html"
  }
}
